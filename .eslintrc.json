{
  "env": {
    "node": true,
    "es6": true,
    "browser": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "rules": {
    "no-var": "error",
    "semi": ["error", "always"],
    "no-console": "warn",
    "eqeqeq": "error",
    "camelcase": "warn"
  }
}